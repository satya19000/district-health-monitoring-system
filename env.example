# InsForge backend configuration (PUBLIC values only - safe for frontend)
# Copy this file to ".env" and fill in your project values.

# Your InsForge project base URL
VITE_INSFORGE_URL=https://fzdjms6v.ap-southeast.insforge.app

# Your InsForge PUBLIC anon key (NOT the admin/secret api key).
# Get it from the InsForge dashboard. The anon key is designed to be
# shipped in frontend code; it only allows what your RLS policies permit.
VITE_INSFORGE_ANON_KEY=

# AI gateway model slug to use for file analysis.
# Must be a model enabled in your InsForge AI gateway.
VITE_AI_MODEL=openai/gpt-4o-mini

# Default role assigned to users who self-register (lowest privilege).
VITE_DEFAULT_ROLE=ASHA
